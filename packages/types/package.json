{
  "name": "@theseus-cwl/types",
  "description": "Collection of internal typescript definitions.",
  "version": "1.1.2",
  "author": "davide giorgiutti",
  "license": "MIT",
  "keywords": [
    "cwl",
    "common-workflow-language",
    "types",
    "typescript",
    "workflow",
    "theseus-cwl"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE-MIT"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@theseus-cwl/eslint-config": "*",
    "@theseus-cwl/typescript-config": "*",
    "eslint": "^9.23.0",
    "tsup": "^8.5.0"
  }
}