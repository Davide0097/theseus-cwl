{
  "name": "@theseus-cwl/parser",
  "description": "Parse and normalize raw CWL (Common Workflow Language) sources into a consistent, typed, sanitized shape.",
  "version": "0.0.2",
  "author": "davide giorgiutti",
  "license": "MIT",
  "keywords": [
    "cwl",
    "common-workflow-language",
    "parser",
    "workflow",
    "yaml",
    "theseus-cwl"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE-MIT"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@theseus-cwl/eslint-config": "*",
    "@theseus-cwl/typescript-config": "*",
    "eslint": "^9.23.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@theseus-cwl/types": "^1.1.2",
    "yaml": "^2.8.1"
  }
}