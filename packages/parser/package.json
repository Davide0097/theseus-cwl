    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@theseus-cwl/typescript-config": "*",
    "@theseus-cwl/types": "*",
    "typescript": "^5.8.2",
    "tsup": "^8.5.0"
  },
  "dependencies": {
    "@theseus-cwl/configurations": "^1.1.2",
    "yaml": "^2.8.1"
  }
}