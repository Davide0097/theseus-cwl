{
  "name": "@theseus-cwl/configurations",
  "description": "Collection of internal static configurations.",
  "version": "1.1.2",
  "author": "davide giorgiutti",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "build": "tsup src/index.ts --format esm --dts",
    "check-types": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE-MIT"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@theseus-cwl/typescript-config": "*",
    "typescript": "^5.8.2",
    "tsup": "^8.5.0"
  }
}